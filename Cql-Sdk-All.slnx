<Solution>
  <Configurations>
    <Platform Name="Any CPU" />
    <Platform Name="x64" />
    <Platform Name="x86" />
  </Configurations>
  <Folder Name="/(Internal Tools)/">
    <Project Path="tools/XsdToCSharpConverter/XsdToCSharpConverter.csproj" />
    <Project Path="tools/XsdToCSharpConverterTests/XsdToCSharpConverterTests.csproj" />
  </Folder>
  <Folder Name="/(Solution Items)/">
    <File Path=".editorconfig" />
    <File Path=".gitattributes" />
    <File Path=".github/copilot-instructions.md" />
    <File Path=".gitignore" />
    <File Path=".gitmodules" />
    <File Path="build-local-nuget.ps1" />
    <File Path="build-publicapi.ps1" />
    <File Path="build.ps1" />
    <File Path="build.sh" />
    <File Path="cql-base.props" />
    <File Path="LICENSE" />
    <File Path="NuGet.config" />
    <File Path="packaging-tooling.props" />
    <File Path="packaging-tooling.Targets.xml" />
    <File Path="README.md" />
  </Folder>
  <Folder Name="/CQL Packaging CLI/">
    <Project Path="Cql/PackagerCLI/PackagerCLI.csproj" />
  </Folder>
  <Folder Name="/CQL SDK/">
    <File Path=".editorconfig" />
    <File Path="cql-sdk.props" />
    <Project Path="Cql/Cql/Cql.csproj" />
  </Folder>
  <Folder Name="/CQL SDK/00 Runtime/">
    <Project Path="Cql/Cql.Abstractions/Cql.Abstractions.csproj" />
    <Project Path="Cql/Cql.Runtime/Cql.Runtime.csproj" />
    <Project Path="Cql/Iso8601/Iso8601.csproj" />
  </Folder>
  <Folder Name="/CQL SDK/10 Model/">
    <Project Path="Cql/Cql.Firely/Cql.Firely.csproj" />
    <Project Path="Cql/Cql.Model/Cql.Model.csproj" />
  </Folder>
  <Folder Name="/CQL SDK/20 Cql to Elm/">
    <Project Path="Cql/Cql.CqlToElm/Cql.CqlToElm.csproj" />
    <Project Path="Cql/Cql.Grammar/Cql.Grammar.csproj" />
    <Project Path="Cql/Elm/Elm.csproj" />
  </Folder>
  <Folder Name="/CQL SDK/30 Elm to C#/">
    <Project Path="Cql/CodeGeneration.NET/CodeGeneration.NET.csproj" />
    <Project Path="Cql/Cql.Compiler/Cql.Compiler.csproj" />
  </Folder>
  <Folder Name="/CQL SDK/40 FHIR Resource Packaging/">
    <Project Path="Cql/Cql.Packaging/Cql.Packaging.csproj" />
  </Folder>
  <Folder Name="/CQL SDK/55 Library Invocation/">
    <Project Path="Cql/Cql.Invocation/Cql.Invocation.csproj" />
  </Folder>
  <Folder Name="/Demo/">
    <File Path="Demo/cql-demo.props" />
  </Folder>
  <Folder Name="/Demo/00 MSBuild Tooling/">
    <Project Path="Demo/Cql/Cql.csproj" />
  </Folder>
  <Folder Name="/Demo/10 Demo Projects/">
    <Project Path="Demo/Measures.Authoring/Measures.Authoring.csproj">
      <BuildDependency Project="Cql/PackagerCLI/PackagerCLI.csproj" />
    </Project>
    <Project Path="Demo/Measures.Demo/Measures.Demo.csproj">
      <BuildDependency Project="Cql/PackagerCLI/PackagerCLI.csproj" />
    </Project>
    <Project Path="Demo/Measures.dqm-content-qicore-2025/Measures.dqm-content-qicore-2025.csproj" />
  </Folder>
  <Folder Name="/Demo/20 Demo CLI/">
