    <Project Path="Demo/Test.Measures.Demo/Test.Measures.Demo.csproj">
      <BuildDependency Project="Cql/PackagerCLI/PackagerCLI.csproj" />
      <BuildDependency Project="Demo/Measures.Demo/Measures.Demo.csproj" />
    </Project>
  </Folder>
  <Properties Name="ExtensibilityGlobals" Scope="PostLoad">
    <Property Name="FileExplorer" Value="build\|docs\|LibrarySets\|" />
  </Properties>
</Solution>
