<?xml version="1.0" encoding="utf-8" ?>
<Project>

	<!-- #### Download Java Tooling Dependencies -->

	<PropertyGroup>
		<TargetDependencies>$(MSBuildThisFileDirectory)/target/dependency</TargetDependencies>
	</PropertyGroup>

	<!-- Windows: Use PowerShell scripts -->
	<PropertyGroup Condition="'$(OS)' == 'Windows_NT'">
		<CleanJavaDependenciesScript>pwsh -File "$(MSBuildThisFileDirectory)/Java-Dependencies-Clean.ps1"</CleanJavaDependenciesScript>
		<DownloadJavaDependenciesScript>pwsh -File "$(MSBuildThisFileDirectory)/Java-Dependencies-Download.ps1"</DownloadJavaDependenciesScript>
	</PropertyGroup>

	<!-- Unix: Use Bash scripts -->
	<PropertyGroup Condition="'$(OS)' != 'Windows_NT'">
		<CleanJavaDependenciesScript>bash "$(MSBuildThisFileDirectory)/Java-Dependencies-Clean.sh"</CleanJavaDependenciesScript>
		<DownloadJavaDependenciesScript>bash "$(MSBuildThisFileDirectory)/Java-Dependencies-Download.sh"</DownloadJavaDependenciesScript>
	</PropertyGroup>

	<ItemGroup>
		<Folder Include="$(TargetDependencies)" />
	</ItemGroup>

	<Target
		Name="Download CQL to ELM CLI"
		Condition="'$(CqlToElmEnabled)'=='true' And ('$(TargetFramework)' == 'net10.0' Or '$(TargetFramework)' == '')"
		BeforeTargets="PreBuildEvent">
		<Exec Command="$(DownloadJavaDependenciesScript)" ContinueOnError="false" />
	</Target>

	<ItemGroup>
		<JarDependencies Include="$(TargetDependencies)/*.jar" />
	</ItemGroup>

	<Target
		Name="Delete JAR Dependencies"
		AfterTargets="Clean">
		<Exec Command="$(CleanJavaDependenciesScript)" />
	</Target>

	<!-- #### CQL to ELM Target -->

	<PropertyGroup>
		<!-- Turn off visual studio msbuild automatics -->
		<AccelerateBuildsInVisualStudio>false</AccelerateBuildsInVisualStudio>
		<DisableFastUpToDateCheck>true</DisableFastUpToDateCheck>
		<BoxHeader>$(MSBuildProjectName) </BoxHeader>
		<BoxFooter>LibrarySet='$(LibrarySet)', Configuration='$(Configuration)'</BoxFooter>
		<Box>$(Box.Replace({Text}, | $(BoxHeader){Text}&#10;| $(BoxFooter)))</Box>
	</PropertyGroup>

	<!-- CQL to ELM -->
	<ItemGroup>
		<CqlFiles Include="$(CqlDirectory)/*.cql" />
	</ItemGroup>

	<PropertyGroup>

		<!-- For certain Java tooling version use on or the other -->
		<JavaCommand>java</JavaCommand>
		<!-- <JavaCommand>java -Djakarta.xml.bind.JAXBContextFactory=org.eclipse.persistence.jaxb.XMLBindingContextFactory</JavaCommand> -->

		<ClassPath>-classpath $(TargetDependencies)/* org.cqframework.cql.cql2elm.cli.Main</ClassPath>
		<JavaOutputFile>$(MSBuildProjectDirectory)/elm-build.log</JavaOutputFile>
		<JavaArgs>-input $(CqlDirectory) -f JSON -output $(ElmDirectory) -locators true -result-types true -signatures All</JavaArgs>
		<JavaCLI>"$(JavaCommand)" $(ClassPath) $(JavaArgs)</JavaCLI>
	</PropertyGroup>

	<Target Name="GenerateElmFiles"
	        Inputs="@(CqlFiles)"
	        Outputs="@(CqlFiles->'$(ElmDirectory)/%(FileName).json')"
	        Condition="'$(CqlToElmEnabled)'=='true' And '$(LibrarySet)'!='' And ('$(TargetFramework)' == 'net10.0' Or '$(TargetFramework)' == '')"
	        BeforeTargets="PreBuildEvent">

		<ItemGroup>
			<ElmFiles Include="$(ElmDirectory)/*.json"/>
		</ItemGroup>

		<!-- Delete old ELM files -->
		<Message Text="$(Box.Replace({Text}, Deleting ELM files))" Importance="High" />

		<Delete Files="@(ElmFiles)" />

		<!-- Generate ELM files -->
		<Message
			Text="$(Box.Replace({Text}, Generating ELM&#10;| $(JavaCLI)))" Importance="High" />

		<Exec
			Command="java --version"
			ConsoleToMSBuild="true">
			<Output TaskParameter="ConsoleOutput" ItemName="OutputOfExec" />
		</Exec>

		<Exec
			Command="$(JavaCLI)"
			ConsoleToMSBuild="true">
			<Output TaskParameter="ConsoleOutput" ItemName="OutputOfExec" />
		</Exec>

		<WriteLinesToFile
			File="$(JavaOutputFile)"
      Lines="@(OutputOfExec)"
      Overwrite="true"
      Encoding="Unicode"/>

		<!-- Set a property to indicate that the task ran -->
		<CreateProperty
			Value="true">
			<Output TaskParameter="ValueSetByTask" PropertyName="CQLtoElmRan" />
		</CreateProperty>

	</Target>

	<Target Name="CleanElmFiles"
	        Condition="'$(CqlToElmEnabled)'=='true'"
					AfterTargets="Clean">
		<ItemGroup>
			<ElmFiles Include="$(ElmDirectory)/*.json"/>
		</ItemGroup>
		<Message Text="$(Box.Replace({Text}, Deleting ELM files))" Importance="High" />
		<Delete Files="@(ElmFiles)" />
	</Target>

</Project>