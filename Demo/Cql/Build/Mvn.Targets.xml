<?xml version="1.0" encoding="utf-8"?>

<Project>
	<!-- Download/Clean Java Dependencies using Maven -->

	<PropertyGroup>
		<CleanJavaDependenciesScript>$(MSBuildThisFileDirectory)Java-Dependencies-Clean.ps1</CleanJavaDependenciesScript>
		<DownloadJavaDependenciesScript>$(MSBuildThisFileDirectory)Java-Dependencies-Download.ps1</DownloadJavaDependenciesScript>
	</PropertyGroup>

	<ItemGroup>
		<Folder Include="$(TargetDependencies)" />
	</ItemGroup>

	<Target
		Name="Download CQL to ELM CLI"
		BeforeTargets="PreBuildEvent">
		<Exec Command="pwsh -File &quot;$(DownloadJavaDependenciesScript)&quot;" />
	</Target>

	<ItemGroup>
		<JarDependencies Include="$(TargetDependencies)/*.jar" />
	</ItemGroup>

	<Target
		Name="Delete JAR Dependencies"
		AfterTargets="Clean">
		<Exec Command="pwsh -File &quot;$(CleanJavaDependenciesScript)&quot;" />
	</Target>

</Project>