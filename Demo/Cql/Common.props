<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

	<PropertyGroup>
		<AccelerateBuildsInVisualStudio>false</AccelerateBuildsInVisualStudio>
		<CqlToElmCliVersion>3.1.0</CqlToElmCliVersion>
	</PropertyGroup>

	<PropertyGroup>
		<BoxLine>______________________________</BoxLine>
		<Box> $(BoxLine)&#10;/&#10;| {BoxHeader}: {Text}&#10;\$(BoxLine)</Box>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)' == 'Release'">
		<CqlToElmEnabled>true</CqlToElmEnabled>
		<ElmToCSharpEnabled>true</ElmToCSharpEnabled>
		<EmbedDebugSymbolsEnable>false</EmbedDebugSymbolsEnable>
		<JsonPretty>true</JsonPretty>
	</PropertyGroup>

	<PropertyGroup Condition="'$(Configuration)' != 'Release'">
		<CqlToElmEnabled>false</CqlToElmEnabled>
		<ElmToCSharpEnabled>true</ElmToCSharpEnabled>
		<EmbedDebugSymbolsEnable>true</EmbedDebugSymbolsEnable>
		<JsonPretty>true</JsonPretty>
	</PropertyGroup>

</Project>