<Project Sdk="Microsoft.NET.Sdk">
	<Import Project="..\cql-demo.props" />

	<PropertyGroup>
		<OutputType>Exe</OutputType>
		<Configurations>Debug;Release</Configurations>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Cql\Cql.Abstractions\Cql.Abstractions.csproj" />
		<ProjectReference Include="..\..\Cql\Cql.Runtime\Cql.Runtime.csproj" />
		<ProjectReference Include="..\CLI\CLI.csproj" />
		<PackageReference Include="Hl7.Fhir.R4" Version="$(FirelySdkVersion)" />
	</ItemGroup>

	<PropertyGroup>
		<LibrarySet>Measures.Authoring</LibrarySet>
		<CqlDir>$(MSBuildProjectDirectory)/input/cql</CqlDir>
		<ElmDir>$(MSBuildProjectDirectory)/Elm</ElmDir>
		<CSharpDir>$(MSBuildProjectDirectory)/CSharp</CSharpDir>
		<FhirDir>$(MSBuildProjectDirectory)/Resources</FhirDir>
		<TestResultsDirectory>$(MSBuildProjectDirectory)/input/tests/results</TestResultsDirectory>
	</PropertyGroup>

	<Import Project="$(CqlSolutionDir)/tools/cql/cql-tooling.targets" />

	<ItemGroup>
		<Compile Include="..\..\Cql\Cql.Runtime\Runtime\DirectoryInfoExtensions.cs" Link="Helpers\DirectoryInfoExtensions.cs" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="input/**">
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</Content>
		<Content Remove="input/tests/results" />
	</ItemGroup>

	<ItemGroup>
		<Content Include="Resources/*.*">
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<ItemGroup>
	  <Compile Remove="Resources\**" />
	  <Content Remove="Resources\**" />
	  <EmbeddedResource Remove="Resources\**" />
	  <None Remove="Resources\**" />
	</ItemGroup>

	<ItemGroup>
	  <Folder Include="CSharp\" />
	  <Folder Include="Elm\" />
	  <Folder Include="Input\cql\" />
	</ItemGroup>

</Project>
