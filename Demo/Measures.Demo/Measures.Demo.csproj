<Project Sdk="Microsoft.NET.Sdk">

	<Import Project="..\cql-demo.props" />

	<PropertyGroup>
		<Configurations>Debug;Release</Configurations>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\..\Cql\Cql.Abstractions\Cql.Abstractions.csproj" />
		<ProjectReference Include="..\..\Cql\Cql.Runtime\Cql.Runtime.csproj" />
		<ProjectReference Include="..\CLI\CLI.csproj" />
		<PackageReference Include="Hl7.Fhir.R4" Version="$(FirelySdkVersion)" />
		<!-- Ensure the PackagerCLI is build first, so that the ElmToCSharp targets file succeeds -->
		<ProjectReference Include="..\..\Cql\PackagerCLI\PackagerCLI.csproj" />
	</ItemGroup>

	<PropertyGroup>
		<TestResultsDirectory>$(MSBuildProjectDirectory)/input/tests/results</TestResultsDirectory>
		<OutputType>Exe</OutputType>
	</PropertyGroup>

  <ItemGroup>
    <Compile Include="..\..\Cql\Cql.Runtime\Runtime\DirectoryInfoExtensions.cs" Link="Helpers\DirectoryInfoExtensions.cs" />
  </ItemGroup>

	<ItemGroup>
		<Content Include="input/**">
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</Content>
		<Content Remove="input/tests/results" />
	</ItemGroup>

	<!--
	Packaging tooling properties. Put these last
	-->
	<Import Project="..\..\packaging-tooling.props" />

	<PropertyGroup>
		<!-- Use CqlSolutionDir instead of SolutionDir, because this file is used in different solutions across repos -->
		<LibrarySet>Demo</LibrarySet>
		<LibrarySetRoot>$(CqlSolutionDir)LibrarySets/$(LibrarySet)</LibrarySetRoot>
		<CqlDirectory>$(LibrarySetRoot)/Cql</CqlDirectory>
		<ElmDirectory>$(LibrarySetRoot)/Elm</ElmDirectory>
		<CSharpDirectory>$(MSBuildProjectDirectory)/CSharp</CSharpDirectory>
		<ResourcesDirectory>$(LibrarySetRoot)/Resources</ResourcesDirectory>
		<!--
			ElmToCSharpEnabled: This must always be true on the build server,
			so that resources (that are not checked in), can be build, in order
			for the MeasureTest.BCSEHEDIS2022_Numerator_FromResource_Passed to run.
		-->
		<ElmToCSharpEnabled Condition="'$(TF_BUILD)' == 'True'">true</ElmToCSharpEnabled>
	</PropertyGroup>

	<ItemGroup>
		<Content Include="$(CqlDirectory)/*">
			<Link>input/cql/%(Filename)%(Extension)</Link>
		</Content>
	</ItemGroup>

	<ItemGroup>
		<Content Include="$(ElmDirectory)/*">
			<Link>Elm/%(Filename)%(Extension)</Link>
		</Content>
	</ItemGroup>

	<ItemGroup>
		<Content Include="$(ResourcesDirectory)/*">
			<Link>Resources/%(Filename)%(Extension)</Link>
			<CopyToOutputDirectory>Never</CopyToOutputDirectory>
		</Content>
	</ItemGroup>

	<Import Project="..\..\packaging-tooling.Targets.xml" />

</Project>
