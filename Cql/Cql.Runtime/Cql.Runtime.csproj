 <Project Sdk="Microsoft.NET.Sdk">

	<Import Project="..\..\cql-sdk.props" />

	<PropertyGroup>
		<AssemblyName>Hl7.Cql.Runtime</AssemblyName>
		<RootNamespace>Hl7.Cql</RootNamespace>
		<Product>CQL engine runtime</Product>
		<Description>Support package for Hl7.Cql. Contains the required runtime components for CQL execution.</Description>
		<Configurations>Debug;Release</Configurations>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\Cql.Abstractions\Cql.Abstractions.csproj" />
		<PackageReference Include="Microsoft.Extensions.Logging.Debug" Version="8.0.0" />
		<PackageReference Include="Fhir.Metrics" Version="1.3.0" />
	</ItemGroup>

	<ItemGroup>
		<InternalsVisibleTo Include="Hl7.Cql.CodeGeneration.NET" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.Fhir" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.Compiler" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.Packaging" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.Model" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.CqlToElm" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.Invocation" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="CqlToElmTests" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.Elm" Key="$(LibraryPKHash)" />
		<InternalsVisibleTo Include="Hl7.Cql.MultiPackager" Key="$(LibraryPKHash)" />
	</ItemGroup>

	<ItemGroup>
	  <Compile Update="Operators\CqlOperators.*.cs">
	    <DependentUpon>Operators\CqlOperators.cs</DependentUpon>
	  </Compile>

	  <Compile Update="Comparers\CqlComparers.*.cs">
	    <DependentUpon>Comparers\CqlComparers.cs</DependentUpon>
	  </Compile>
	</ItemGroup>

</Project>
