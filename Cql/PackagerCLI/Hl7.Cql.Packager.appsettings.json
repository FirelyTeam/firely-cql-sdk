{
  "Logging": {
    "ConsoleLogLevel": "Information", // --console-log-level "Trace", "Debug", "Information", "Warning", "Error", "Critical" or "None"
    "FileLogLevel": "Information", // --file-log-level "Trace", "Debug", "Information", "Warning", "Error", "Critical" or "None"
    "Append": false, // --log-append
  },
  "Cql": {
    "Models": [ "ElmR1", "Fhir401" ],
    "AmbiguousTypeBehavior": "PreferModel", // "Error", "PreferSystem" or "PreferModel"
    "SystemElmModelUri": "urn:hl7-org:elm-types:r1",
    "SystemElmModelVersion": "1.0.0",
    "DisableListDemotion": true,
    "DisableListPromotion": true,
    "EnableIntervalDemotion": true,
    "EnableIntervalPromotion": true,
    "AllowNullIntervals": false,
    "ValidateIntervals": false,
    "LongsRequireSuffix": true,
    "ValidateLiterals": true
  },
  "Elm": {
    "AllowInvalidCSharp": true,
    "JsonPretty": false, // --json-pretty
    "DebugSymbolsFormat": "None", // --debug-symbols : "None", "PortablePdb", "Embedded"
    "SkipFiles": [
      // JSON Files that are skipped during the packaging process.
      // See the specific profile appsettings e.g. Hl7.Cql.Packager.appsettings.CMSMeasures.json
    ]
  },
  "Packaging": {
    "JsonPretty": false, // --json-pretty
    "ExitOnError": false,
    "CanonicalRootUrl": "https://fire.ly/fhir/", // --canonical-root-url
    "OverrideDate": null, // --override-utc-date-time eg. "2023-10-01T00:00:00Z",
    "FixedLibraryCanonicals": {
      "FHIRHelpers": "https://fhir.org/guides/cqf/common/Library/FHIRHelpers"
    }
  }
}