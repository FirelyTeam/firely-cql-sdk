<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<CqlToolsDir Condition="'$(CqlToolsDir)' == ''">$(CqlSolutionDir)tools\cql\</CqlToolsDir>
		<CqlToElmProject Condition="'$(CqlToElmProject)' == ''">$(CqlToolsDir)cql-to-elm.proj</CqlToElmProject>
		<ElmToResourceProject Condition="'$(ElmToResourceProject)' == ''">$(CqlToolsDir)elm-to-resource.proj</ElmToResourceProject>
	</PropertyGroup>
	<ItemGroup>
		<CqlFiles Include="$(CqlDir)\*.cql" />
		<ElmFiles Include="$(ElmDir)\*.json" />
		<GeneratedFiles Include="$(CSharpDir)\*.g.cs" />
	</ItemGroup>

	<Target Name="CompileCql"
	      BeforeTargets="BeforeBuild"
	      Inputs="@(CqlFiles)"
	      Outputs="@(ElmFiles)"
	      Condition="Exists('$(CqlDir)')">
		<Message Text="[tooling] CompileCql - CqlDir: $(CqlDir), ElmDir: $(ElmDir)" Importance="High" />
		<MSBuild Projects="$(CqlToElmProject)"
		         Targets="CompileCqlFiles"
		         Properties="CqlSolutionDir=$(CqlSolutionDir);Configuration=$(Configuration);TargetFramework=$(TargetFramework);CqlDir=$(CqlDir);ElmDir=$(ElmDir);CqlVersion=$(CqlVersion)" />
	</Target>

	<Target Name="ConvertElmToResources"
	      BeforeTargets="CoreCompile"
	      Inputs="@(ElmFiles)"
	      Outputs="$(CSharpDir)\.cs-generated.marker;$(DllDir)\.dll-generated.marker;$(FhirDir)\.fhir-generated.marker"
	      Condition="Exists('$(ElmDir)')">
		<Message Text="[tooling] ConvertElmToResources - ElmDir: $(ElmDir), CSharpDir: $(CSharpDir), DllDir: $(DllDir), FhirDir: $(FhirDir)" Importance="High" />
		<MSBuild Projects="$(ElmToResourceProject)"
		         Targets="ElmToResources"
		         Properties="CqlSolutionDir=$(CqlSolutionDir);Configuration=$(Configuration);TargetFramework=$(TargetFramework);CqlDir=$(CqlDir);ElmDir=$(ElmDir);CSharpDir=$(CSharpDir);DllDir=$(DllDir);FhirDir=$(FhirDir)" />
		<Touch Files="$(ElmDir)\.elm-generated.marker" AlwaysCreate="true" />
	</Target>

	<Target Name="CleanCqlToolingArtifacts"
	      AfterTargets="Clean;Rebuild"
	      Condition="Exists('$(ElmDir)') Or Exists('$(CSharpDir)') Or Exists('$(DllDir)') Or Exists('$(FhirDir)')">
		<Message Text="[tooling] CleanCqlToolingArtifacts - ElmDir: $(ElmDir), CSharpDir: $(CSharpDir), DllDir: $(DllDir), FhirDir: $(FhirDir)" Importance="High" />
		<MSBuild Projects="$(CqlToElmProject)"
		        Targets="CleanCqlToElm"
		        Properties="ElmDir=$(ElmDir)" />
		<MSBuild Projects="$(ElmToResourceProject)"
		         Targets="CleanElmToResources"
		         Properties="CqlSolutionDir=$(CqlSolutionDir);Configuration=$(Configuration);TargetFramework=$(TargetFramework);CSharpDir=$(CSharpDir);DllDir=$(DllDir);FhirDir=$(FhirDir)" />
	</Target>
</Project>