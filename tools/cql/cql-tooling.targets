<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<CqlToolsDir Condition="'$(CqlToolsDir)' == ''">$(CqlSolutionDir)tools\cql\</CqlToolsDir>
	</PropertyGroup>

	<ItemGroup>
		<CqlFiles Include="$(CqlDir)\*.cql" />
		<ElmFiles Include="$(ElmDir)\*.json" />
		<CSharpFiles Include="$(CSharpDir)\*.g.cs" />
		<DllFiles Include="$(DllDir)\*.dll" />
		<FhirFiles Include="$(FhirDir)\*.json" />
	</ItemGroup>

	<PropertyGroup>
		<JavaClasspath>$(CqlToolsDir)target\dependency\*</JavaClasspath>
		<MainClass>org.cqframework.cql.cql2elm.cli.Main</MainClass>
		<PackagerExe Condition=" '$(PackagerExe)' == ''">$(CqlSolutionDir)Cql/PackagerCLI/bin/$(Configuration)/$(TargetFramework)/Hl7.Cql.Packager.exe</PackagerExe>
	</PropertyGroup>

	<Target Name="EnsureCqlTooling"
	        Inputs="$(CqlToolsDir)pom.xml"
	        Outputs="$(CqlToolsDir)target\dependency\cql-to-elm-cli-$(CqlVersion).jar">
		<Message Text="[>>>EnsureCqlTooling] Ensuring Java dependencies via Maven..." Importance="High" />
		<Exec WorkingDirectory="$(CqlToolsDir)"
		      Command="mvn dependency:copy-dependencies" />
	</Target>

	<Target Name="CompileCql"
        BeforeTargets="CoreCompile"
        Inputs="@(CqlFiles)"
        Outputs="@(CqlFiles->'$(ElmDir)\%(Filename).json')"
        Condition="'@(CqlFiles)' != ''">
		<MakeDir Directories="$(ElmDir)" Condition="!Exists('$(ElmDir)')" />
		<Message Text="[>>>CompileCql] CqlDir: $(CqlDir), ElmDir: $(ElmDir)" Importance="High" />
		<CallTarget Targets="EnsureCqlTooling" />
		<Exec Command='java -cp "$(JavaClasspath)" $(MainClass) -input "$(CqlDir)" -output "$(ElmDir)" -f JSON -locators true -result-types true -signatures All' />
	</Target>

	<Target Name="ConvertElmToResources"
	        AfterTargets="CompileCql"
        BeforeTargets="CoreCompile"
        Inputs="@(ElmFiles)"
        Outputs="@(ElmFiles->'$(CSharpDir)\%(Filename).g.cs');@(ElmFiles->'$(DllDir)\%(Filename).dll');@(ElmFiles->'$(FhirDir)\%(Filename).json')"
        Condition="'@(ElmFiles)' != ''">
		<Message Text="[>>>ConvertElmToResources] ElmDir: $(ElmDir), CSharpDir: $(CSharpDir), DllDir: $(DllDir), FhirDir: $(FhirDir)" Importance="High" />
		<Error Condition="!Exists('$(PackagerExe)')" Text="Required packager executable not found: $(PackagerExe)" />
		<ItemGroup>
			<PackagerArgs Include="--cs &quot;$(CSharpDir)&quot;" Condition=" '$(CSharpDir)' != '' " />
			<PackagerArgs Include="--dll &quot;$(DllDir)&quot;" Condition=" '$(DllDir)' != '' " />
			<PackagerArgs Include="--fhir &quot;$(FhirDir)&quot;" Condition=" '$(FhirDir)' != '' " />
		</ItemGroup>
		<Message Text="[>>>ConvertElmToResources] PackagerExe: $(PackagerExe)" Importance="High" />
		<Exec Command="&quot;$(PackagerExe)&quot; elm --file-log-level None --json-pretty --cql &quot;$(CqlDir)&quot; --elm &quot;$(ElmDir)&quot; @(PackagerArgs->'%(Identity)', ' ')"
					WorkingDirectory="$(MSBuildProjectDirectory)"/>
	</Target>

	<Target Name="CleanCqlToElm"
	        AfterTargets="Clean;Rebuild"
	        Condition="'@(ElmFiles)' != ''">
		<Message Text="[>>>CleanCqlToElm] ElmDir: $(ElmDir)" Importance="High" />
		<RemoveDir Directories="$(ElmDir)" Condition="Exists('$(ElmDir)')" />
	</Target>

	<Target Name="CleanElmToResources"
        AfterTargets="Clean;Rebuild"
        Condition="'@(CSharpFiles)' != '' Or '@(DllFiles)' != '' Or '@(FhirFiles)' != ''">
		<Message Text="[>>>CleanElmToResources] Cleaning output directories..." Importance="High" />
		<RemoveDir Directories="$(CSharpDir)" Condition="Exists('$(CSharpDir)')" />
		<RemoveDir Directories="$(DllDir)" Condition="Exists('$(DllDir)')" />
		<RemoveDir Directories="$(FhirDir)" Condition="Exists('$(FhirDir)')" />
	</Target>
</Project>
