<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
	<PropertyGroup>
		<CqlToolsDir Condition="'$(CqlToolsDir)' == ''">$(MSBuildThisFileDirectory)</CqlToolsDir>
	</PropertyGroup>

	<ItemGroup>
		<CqlFiles Include="$(CqlDir)\*.cql" />
		<ElmFiles Include="$(ElmDir)\*.json" />
		<GeneratedFiles Include="$(CSharpDir)\*.g.cs" />
	</ItemGroup>

	<Target Name="CompileCql"
	        BeforeTargets="BeforeBuild"
	        Inputs="@(CqlFiles)"
	        Outputs="@(ElmFiles)"
	        Condition="Exists('$(CqlDir)')">
		<Message Text="### Checking for CQL changes in $(CqlDir)..." Importance="High" />
		<MSBuild Projects="$(CqlToElmProject)"
		         Targets="CompileCqlFiles"
		         Properties="CqlSolutionDir=$(CqlSolutionDir);Configuration=$(Configuration);TargetFramework=$(TargetFramework);CqlDir=$(CqlDir);ElmDir=$(ElmDir);CqlVersion=$(CqlVersion)" />
	</Target>

	<Target Name="ConvertElmToResources"
	        BeforeTargets="CoreCompile"
	        Inputs="@(ElmFiles)"
	        Outputs="@(GeneratedFiles)"
	        Condition="Exists('$(ElmDir)')">
		<Message Text="### Checking for ELM changes in $(ElmDir)..." Importance="High" />
		<MSBuild Projects="$(CqlToolsDir)elm-to-resource.proj"
		         Targets="ElmToResources"
		         Properties="CqlSolutionDir=$(CqlSolutionDir);Configuration=$(Configuration);TargetFramework=$(TargetFramework);CqlDir=$(CqlDir);ElmDir=$(ElmDir);CSharpDir=$(CSharpDir);DllDir=$(DllDir);FhirDir=$(FhirDir)" />
	</Target>

	<Target Name="CleanCqlToolingArtifacts"
	        AfterTargets="Clean"
	        Condition="Exists('$(CSharpDir)') Or Exists('$(DllDir)') Or Exists('$(FhirDir)')">
		<MSBuild Projects="$(CqlToolsDir)elm-to-resource.proj"
		         Targets="CleanElmToResources"
		         Properties="CqlSolutionDir=$(CqlSolutionDir);Configuration=$(Configuration);TargetFramework=$(TargetFramework);CSharpDir=$(CSharpDir);DllDir=$(DllDir);FhirDir=$(FhirDir)" />
	</Target>
</Project>